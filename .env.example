# Neon Database Connection (Required)
# Get this from your Neon dashboard: https://console.neon.tech
# Select your project → Connection Details → Pooled connection string
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/your_database?sslmode=require

# Optional: For migrations with direct connection (unpooled)
# DIRECT_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/your_database?sslmode=require

# Admin Authentication (Required)
# Set a strong password to protect the admin dashboard
ADMIN_PASSWORD=your-secure-admin-password-here

# Session Secret (Required in Production)
# Generate with: openssl rand -base64 32
# Must be at least 32 characters
# The app will fail to start in production without this
SESSION_SECRET=your-random-session-secret-at-least-32-characters-long-here
